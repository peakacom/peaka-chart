# yamllint config for peaka-chart.
#
# Scope: lint only pure-YAML files (values.yaml, Chart.yaml, .drone.yml).
# Helm template files under chart/templates/ contain {{- ... }} directives
# that are not valid YAML pre-render — they are explicitly ignored.
#
# Style choices are calibrated to the existing files, not to upstream
# yamllint defaults. Tightening these later is fine; loosening them tends
# not to happen, so we only relax where the current code requires it.
---
extends: default

ignore: |
  chart/templates/
  chart/charts/
  chart/Chart.lock
  chart/.values*.yaml
  chart/.helmignore
  docs/
  scripts/

rules:
  # values.yaml routinely has long lines (URLs, env-var fragments).
  # Current longest is 156; 160 is a comfortable ceiling without inviting
  # 300-char monsters.
  line-length:
    max: 160
    level: warning

  # Gotcha #5 — booleans must be real booleans, not quoted strings.
  # This is the lint half of that invariant.
  truthy:
    allowed-values: ['true', 'false']
    check-keys: false

  # Chart authors sometimes write `# comment` and sometimes `#comment`.
  # Require the space; it is the larger of the two existing patterns and
  # the more readable.
  comments:
    require-starting-space: true
    min-spaces-from-content: 1

  # values.yaml has comment blocks that intentionally indent to align with
  # values for readability. Don't fight that.
  comments-indentation: disable

  # chart/values.yaml does not start with `---`; .drone.yml does. Either is
  # fine — don't enforce a global choice.
  document-start: disable

  # Block scalar style varies (mostly | and >- as needed) — let authors
  # pick what reads best.
  empty-lines:
    max: 2

  # Helm chart authors occasionally use trailing whitespace inside heredoc
  # certificate blobs. Keep it strict everywhere else.
  trailing-spaces: enable

  # `appVersion: "0.3.51"` is a string-quoted version on purpose
  # (otherwise YAML parses 0.3.51 as a float or version object depending
  # on parser). Don't ban it.
  quoted-strings: disable

  # 2-space indent throughout; sequences indented relative to their key.
  indentation:
    spaces: 2
    indent-sequences: true
    check-multi-line-strings: false
